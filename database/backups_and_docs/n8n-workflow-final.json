        [
          { "node": "Send to WAHA", "type": "main", "index": 0 },
          { "node": "Send an Email", "type": "main", "index": 0 }
        ]
      ]
    },
    "Template: Peminjaman Disetujui": {
      "main": [
        [
          { "node": "Send to WAHA", "type": "main", "index": 0 },
          { "node": "Send an Email", "type": "main", "index": 0 }
        ]
      ]
    },
    "Template: Peminjaman Ditolak": {
      "main": [
        [
          { "node": "Send to WAHA", "type": "main", "index": 0 },
          { "node": "Send an Email", "type": "main", "index": 0 }
        ]
      ]
    },
    "Template: Pengembalian Dicatat": {
      "main": [
        [
          { "node": "Send to WAHA", "type": "main", "index": 0 },
          { "node": "Send an Email", "type": "main", "index": 0 }
        ]
      ]
    },
    "Template: Reminder Terlambat": {
      "main": [
        [
          { "node": "Send to WAHA", "type": "main", "index": 0 },
          { "node": "Send an Email", "type": "main", "index": 0 }
        ]
      ]
    },
    "Template: Alat Diserahkan": {
      "main": [
        [
          { "node": "Send to WAHA", "type": "main", "index": 0 },
          { "node": "Send an Email", "type": "main", "index": 0 }
        ]
      ]
    }
